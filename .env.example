# =============================================================================
# answerbot — environment configuration (template)
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# .env is loaded automatically at startup (see src/run.rs::load_dotenv). Never put real
# secrets in .env.example — it is tracked in git.
#
# Model selection and temperature are configured in config.toml.

# -----------------------------------------------------------------------------
# OpenRouter — LLM provider (chat completions)
# https://openrouter.ai/keys
# -----------------------------------------------------------------------------

# API key for your OpenRouter account. Required.
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Firecrawl — web search + page reader
# https://www.firecrawl.dev/signin
# -----------------------------------------------------------------------------

# API key for your Firecrawl account. Required.
FIRECRAWL_API_KEY=

# -----------------------------------------------------------------------------
# Optional path overrides (defaults assume you run from the repo root)
# -----------------------------------------------------------------------------

# Path to config.toml (default: config.toml)
# ANSWERBOT_CONFIG=config.toml

# Path to the append-only journal (default: journal.jsonl).
# May contain full questions, answers, and reasoning — treat as sensitive.
# ANSWERBOT_JOURNAL=journal.jsonl

# Override the OpenRouter / Firecrawl base URLs (tests / self-hosted proxies).
# ANSWERBOT_OPENROUTER_URL=...
# ANSWERBOT_FIRECRAWL_URL=...
