# --- Rust / Cargo ---
# Build artifacts
/target/

# Cargo.lock is intentionally NOT ignored: this crate is a binary
# (main.rs at the crate root, no [lib] section in Cargo.toml), and the
# Rust community convention is to commit Cargo.lock for binaries.

# --- Environment / secrets ---
# Real env file (may contain secrets); keep the example template tracked.
.env
.env.*
!.env.example

# --- Editors / IDEs ---
# Shared editor config is tracked; everything else in .vscode/ is personal.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo
*~
*.bak

# --- OS noise ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs / runtime artifacts ---
*.log
logs/
# Append-only audit trail written by every run.
journal.jsonl
# Multi-model evaluation harness output (tests/run_eval.py writes here).
results/